{
  "manifest_version": 3,
  "name": "PhishGuard AI Real-Time Protection",
  "version": "1.2.0",
  "description": "Real-time phishing detection powered by PhishGuard AI.",
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "activeTab",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:5001/*",
    "https://phishguard-nodejs.onrender.com/"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
